# Game server — DELIVEROO_HOST must include the scheme (the client appends the port)
DELIVEROO_HOST=http://localhost
DELIVEROO_PORT=8080

# Agent tokens (assigned by the Deliveroo.js server config)
TOKEN_LIAISON=token-a
TOKEN_COURIER=token-b

# LiteLLM — set LITELLM_BASE_URL to point at a proxy; leave blank for direct API
LITELLM_MODEL=gpt-4o
LITELLM_API_KEY=sk-...
LITELLM_BASE_URL=

# Logging: debug | info | warn | error
LOG_LEVEL=info
LOG_DIR=./logs
